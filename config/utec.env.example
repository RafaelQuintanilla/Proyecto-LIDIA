# Variables de entorno para usar la base asignada en UTEC
# Copiar este archivo a config/.env y completar los valores reales.

# PostgreSQL UTEC
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=proyecto_lidia
PG_USER=lidia_etl_user
PG_PASSWORD=CAMBIAR_LOCALMENTE

# MongoDB UTEC
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=proyecto_lidia
MONGO_USER=lidia_mongo_user
MONGO_PASSWORD=CAMBIAR_LOCALMENTE
# Si UTEC cambia la base de autenticacion, ajustar este valor.
MONGO_AUTH_SOURCE=grp03db

# APIs y logs
FIRMS_MAP_KEY=tu_api_key_aqui
CAMS_FILE=
AIR_QUALITY_FILE=
LOG_LEVEL=INFO
TIMEZONE=America/Montevideo
