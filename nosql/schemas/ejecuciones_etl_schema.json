{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Ejecución ETL",
    "description": "Registro de cada ejecución del pipeline ETL con métricas y trazabilidad",
    "required": ["fuente", "etapa", "tipo_carga", "estado", "iniciado_en"],
    "properties": {
      "fuente": {
        "bsonType": "string",
        "enum": ["firms", "firms_nrt", "open-meteo", "open-meteo-forecast", "cams"],
        "description": "Fuente de datos procesada"
      },
      "etapa": {
        "bsonType": "string",
        "enum": ["extract", "transform", "load", "testing", "pipeline_completo"],
        "description": "Etapa del pipeline ejecutada"
      },
      "tipo_carga": {
        "bsonType": "string",
        "enum": ["inicial", "incremental", "test", "reprocess"],
        "description": "Tipo de ejecución"
      },
      "estado": {
        "bsonType": "string",
        "enum": ["ok", "error", "parcial", "skip"],
        "description": "Resultado de la ejecución"
      },
      "iniciado_en": {
        "bsonType": "date",
        "description": "Timestamp UTC de inicio"
      },
      "finalizado_en": {
        "bsonType": ["date", "null"]
      },
      "duracion_segundos": {
        "bsonType": ["double", "null"],
        "minimum": 0
      },
      "metricas": {
        "bsonType": "object",
        "properties": {
          "registros_procesados":   { "bsonType": ["int", "null"] },
          "registros_insertados":   { "bsonType": ["int", "null"] },
          "registros_actualizados": { "bsonType": ["int", "null"] },
          "registros_sin_cambio":   { "bsonType": ["int", "null"] },
          "registros_error":        { "bsonType": ["int", "null"] }
        }
      },
      "rango_datos": {
        "bsonType": "object",
        "description": "Rango temporal de datos procesados",
        "properties": {
          "desde": { "bsonType": ["date", "null"] },
          "hasta": { "bsonType": ["date", "null"] }
        }
      },
      "errores": {
        "bsonType": "array",
        "description": "Lista de errores ocurridos (vacía si estado=ok)",
        "items": {
          "bsonType": "object",
          "properties": {
            "tipo":    { "bsonType": "string" },
            "mensaje": { "bsonType": "string" },
            "en":      { "bsonType": ["date", "null"] }
          }
        }
      },
      "host": {
        "bsonType": "string",
        "description": "Hostname donde corrió el pipeline"
      },
      "version_pipeline": {
        "bsonType": "string",
        "description": "Versión del código del pipeline"
      }
    }
  }
}
