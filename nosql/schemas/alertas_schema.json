{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Alerta de riesgo de incendio",
    "description": "Documento generado cuando el sistema detecta condiciones de riesgo elevado",
    "required": ["tipo_alerta", "fecha_generacion", "fuente", "nivel", "puntos_afectados"],
    "properties": {
      "tipo_alerta": {
        "bsonType": "string",
        "enum": ["riesgo_meteorologico", "focos_detectados", "calidad_aire", "combinada"],
        "description": "Categoría de la alerta"
      },
      "fecha_generacion": {
        "bsonType": "date",
        "description": "Timestamp UTC de generación de la alerta"
      },
      "fuente": {
        "bsonType": "string",
        "enum": ["firms", "open-meteo", "cams", "sistema"],
        "description": "Fuente de datos que disparó la alerta"
      },
      "nivel": {
        "bsonType": "string",
        "enum": ["moderado", "alto", "muy_alto", "critico"],
        "description": "Nivel de severidad de la alerta"
      },
      "puntos_afectados": {
        "bsonType": "array",
        "minItems": 1,
        "description": "Lista de puntos de monitoreo afectados",
        "items": {
          "bsonType": "object",
          "required": ["nombre", "valor_indicador"],
          "properties": {
            "nombre":           { "bsonType": "string" },
            "latitud":          { "bsonType": "double" },
            "longitud":         { "bsonType": "double" },
            "valor_indicador":  { "bsonType": "double" },
            "nivel_punto":      { "bsonType": "string" }
          }
        }
      },
      "indicadores": {
        "bsonType": "object",
        "description": "Valores que dispararon la alerta",
        "properties": {
          "indice_riesgo_max": { "bsonType": "double" },
          "focos_detectados":  { "bsonType": "int" },
          "pm10_max":          { "bsonType": "double" },
          "temperatura_max":   { "bsonType": "double" },
          "humedad_min":       { "bsonType": "double" }
        }
      },
      "mensaje": {
        "bsonType": "string",
        "description": "Descripción legible de la alerta para comunicación"
      },
      "activa": {
        "bsonType": "bool",
        "description": "TRUE si la alerta sigue vigente"
      },
      "resuelta_en": {
        "bsonType": ["date", "null"],
        "description": "Cuando se resolvió la alerta, null si sigue activa"
      }
    }
  }
}
