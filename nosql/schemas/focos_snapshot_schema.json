{
  "$jsonSchema": {
    "bsonType": "object",
    "title": "Snapshot diario de focos de calor",
    "description": "Snapshot completo del estado de focos para un día dado. Permite consultas de estado histórico sin joins complejos. Justificación NoSQL: documentos auto-contenidos por día, flexible ante cambios de esquema de fuente.",
    "required": ["fecha", "generado_en", "total_focos", "focos"],
    "properties": {
      "fecha": {
        "bsonType": "date",
        "description": "Fecha del snapshot (granularidad diaria)"
      },
      "generado_en": {
        "bsonType": "date",
        "description": "Timestamp de generación del snapshot"
      },
      "total_focos": {
        "bsonType": "int",
        "minimum": 0
      },
      "resumen": {
        "bsonType": "object",
        "properties": {
          "frp_promedio":        { "bsonType": ["double", "null"] },
          "frp_maximo":          { "bsonType": ["double", "null"] },
          "focos_alta_confianza":{ "bsonType": "int" },
          "focos_diurnos":       { "bsonType": "int" },
          "focos_nocturnos":     { "bsonType": "int" }
        }
      },
      "focos": {
        "bsonType": "array",
        "description": "Lista de focos detectados en el día",
        "items": {
          "bsonType": "object",
          "required": ["latitud", "longitud"],
          "properties": {
            "latitud":             { "bsonType": "double" },
            "longitud":            { "bsonType": "double" },
            "hora_adq_hhmm":       { "bsonType": ["int", "null"] },
            "potencia_radiativa":  { "bsonType": ["double", "null"] },
            "confianza_raw":       { "bsonType": ["string", "null"] },
            "confianza_num":       { "bsonType": ["int", "null"] },
            "satelite":            { "bsonType": ["string", "null"] },
            "es_diurno":           { "bsonType": ["bool", "null"] }
          }
        }
      },
      "riesgo_del_dia": {
        "bsonType": "object",
        "description": "Contexto de riesgo meteorológico del mismo día (desnormalizado para consultas rápidas)",
        "properties": {
          "indice_promedio_todos_puntos": { "bsonType": ["double", "null"] },
          "nivel_maximo":                { "bsonType": ["string", "null"] },
          "puntos_en_alto_riesgo":       { "bsonType": ["int", "null"] }
        }
      }
    }
  }
}
